# Telegram: https://t.me/BotFather
BOT_TOKEN=

# Twitch developer console: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Kick Developer portal application credentials
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Public-page checks can be blocked by Instagram or TikTok.
# Export browser Cookie header values only when needed; never commit real values.
INSTAGRAM_COOKIE=
TIKTOK_COOKIE=
# Optional HTTP(S) proxy, e.g. http://user:password@host:port
STREAM_PROXY_URL=
# Optional browser-like identifier used for public page checks.
SCRAPE_USER_AGENT=

# Persistent database path. Mount /app/data as a Docker volume.
DB_PATH=/app/data/streams.db

# Twitch and Kick polling interval (minimum 5 seconds).
FAST_POLL_INTERVAL_SECONDS=90
# YouTube, VK and Rutube public-page polling interval (minimum 30 seconds).
YOUTUBE_POLL_INTERVAL_SECONDS=300
# Instagram and TikTok polling interval (minimum 60 seconds).
SLOW_SCRAPE_POLL_INTERVAL_SECONDS=300
# Wait before the first notification; 0 sends it immediately.
COMBINE_DELAY_SECONDS=0
# Timezone used by the {time} placeholder.
NOTIFICATION_TIMEZONE=Europe/Moscow
REQUEST_TIMEOUT=20
LOG_LEVEL=INFO
