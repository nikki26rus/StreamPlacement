# Telegram: https://t.me/BotFather
BOT_TOKEN=

# Twitch developer console: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Google Cloud Console: enable YouTube Data API v3
YOUTUBE_API_KEY=

# Kick Developer portal application credentials
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Persistent database path. Mount /app/data as a Docker volume.
DB_PATH=/app/data/streams.db

# Twitch and Kick polling interval (minimum 5 seconds).
FAST_POLL_INTERVAL_SECONDS=90
# YouTube uses a quota-heavy API request (minimum 30 seconds).
YOUTUBE_POLL_INTERVAL_SECONDS=300
# Wait before the first notification; 0 sends it immediately.
COMBINE_DELAY_SECONDS=0
# Timezone used by the {time} placeholder.
NOTIFICATION_TIMEZONE=Europe/Moscow
REQUEST_TIMEOUT=20
LOG_LEVEL=INFO
